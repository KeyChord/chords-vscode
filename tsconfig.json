{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "allowJs": true,
    "types": ["chord-types", "llrt-types"],
    "paths": {
      "#/*": ["./src/*"]
    },
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
  },
  "include": ["src"]
}
